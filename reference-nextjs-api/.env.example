# Copy to `.env.local` in this folder (Next.js loads it automatically).
# Never commit `.env.local`.

# --- YouTube Shorts proxy (Expo: EXPO_PUBLIC_YOUTUBE_PROXY_URL → this host) ---
# Google Cloud → YouTube Data API v3 → Credentials → API key
YOUTUBE_API_KEY=replace_with_your_youtube_data_api_v3_key

# Set to 1 to log search/list sizes for /api/youtube/shorts (server console only).
# YOUTUBE_PROXY_DEBUG=1

# --- HeyGen LiveAvatar (server) + public ids (client) ---
# app.heygen.com → Settings → API
HEYGEN_API_KEY=replace_with_heygen_api_key
# labs.heygen.com / interactive avatar — used in the browser by the Next /tutor page
NEXT_PUBLIC_HEYGEN_AVATAR_ID=replace_with_avatar_id
NEXT_PUBLIC_HEYGEN_VOICE_ID=replace_with_voice_id

# --- Claude (Maya “brain” for /api/tutor/respond) — never put in the Expo app ---
# console.anthropic.com
ANTHROPIC_API_KEY=replace_with_anthropic_key
# Optional: override default (see Anthropic docs for current model ids)
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
