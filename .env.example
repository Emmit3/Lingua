# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* automatically).
# Never commit real keys — `.env` is gitignored.

# --- YouTube Shorts (required for live Shorts feed) ---
# Run the proxy: `cd reference-nextjs-api && npm install && npm run dev` (default port 3040)
EXPO_PUBLIC_YOUTUBE_PROXY_URL=http://localhost:3040

# Optional: same URL if you host other APIs on one backend
# EXPO_PUBLIC_BACKEND_URL=http://localhost:3040

# Optional overrides (otherwise Profile “study language” builds `q` + hashtags; proxy adds #Shorts if missing)
# EXPO_PUBLIC_YOUTUBE_SEARCH_Q=learn spanish #learnspanish #spanishlessons
# EXPO_PUBLIC_YOUTUBE_MAX_RESULTS=12
# EXPO_PUBLIC_YOUTUBE_FILTER_TAGS=grammar,travel

# Optional reel catalog JSON (used when no YouTube proxy is set)
# EXPO_PUBLIC_REELS_URL=

# Optional fixed reel metadata when loading from YouTube
# EXPO_PUBLIC_REEL_LANGUAGE=es
# EXPO_PUBLIC_REEL_LANGUAGE_LABEL=Spanish

# --- Knot demo (optional) ---
# EXPO_PUBLIC_KNOT_CLIENT_ID=
# EXPO_PUBLIC_KNOT_SESSION_ID=

# --- Misc ---
# EXPO_PUBLIC_WEB_URL=http://localhost:8081
