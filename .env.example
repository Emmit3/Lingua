# Copy to `.env` in this folder (Expo loads EXPO_PUBLIC_* automatically).
# Never commit real keys — `.env` is gitignored.
#
# Shorts checklist (if the feed falls back to mock reels):
# 1) Run the proxy on :3040 — either `npm run dev:with-proxy` from this folder (Expo + proxy together),
#    or `cd reference-nextjs-api && npm install && npm run dev` in a second terminal.
# 2) Confirm Google: `npm run verify:youtube` from this folder (or `cd reference-nextjs-api && npm run verify:youtube`).
# 3) Create `reference-nextjs-api/.env.local` with `YOUTUBE_API_KEY=` from Google Cloud Console
#    (enable YouTube Data API v3 for that key). Never put that key in the Expo app.
# 4) Restart Expo after editing this file: `npx expo start --clear`
# 5) Physical iPhone/Android over Wi‑Fi: `localhost` is wrong — use your PC’s LAN IP, e.g.
#    EXPO_PUBLIC_YOUTUBE_PROXY_URL=http://192.168.1.23:3040
#    (Android emulator auto-rewrites localhost→10.0.2.2 in code; real devices do not.)

# --- YouTube Shorts (required for live Shorts feed) ---
# Proxy: `npm run dev:with-proxy` (Expo + proxy) or `npm run proxy:dev` / `cd reference-nextjs-api && npm run dev`
EXPO_PUBLIC_YOUTUBE_PROXY_URL=http://localhost:3040

# Optional: same URL if you host other APIs on one backend
# EXPO_PUBLIC_BACKEND_URL=http://localhost:3040

# Optional: HeyGen + Claude tutor lab (defaults to {PROXY}/tutor). Physical devices: use LAN IP, not localhost.
# EXPO_PUBLIC_TUTOR_LAB_URL=http://192.168.1.23:3040/tutor

# Optional overrides (otherwise Profile “study language” builds `q` + hashtags; proxy adds #Shorts if missing)
# EXPO_PUBLIC_YOUTUBE_SEARCH_Q=learn spanish #learnspanish #spanishlessons
# EXPO_PUBLIC_YOUTUBE_MAX_RESULTS=12
# EXPO_PUBLIC_YOUTUBE_FILTER_TAGS=grammar,travel

# Optional reel catalog JSON (used when no YouTube proxy is set)
# EXPO_PUBLIC_REELS_URL=

# Optional fixed reel metadata when loading from YouTube
# EXPO_PUBLIC_REEL_LANGUAGE=es
# EXPO_PUBLIC_REEL_LANGUAGE_LABEL=Spanish

# --- Knot demo (optional) ---
# EXPO_PUBLIC_KNOT_CLIENT_ID=
# EXPO_PUBLIC_KNOT_SESSION_ID=

# --- Misc ---
# EXPO_PUBLIC_WEB_URL=http://localhost:8081
