{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Expo: start (interactive)",
      "type": "shell",
      "command": "npx expo start",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Expo: open iPhone web frame",
      "type": "shell",
      "command": "node scripts/open-iphone-frame.cjs",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Expo: Web",
      "type": "shell",
      "command": "npx expo start --web",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "Expo: iOS Simulator (macOS)",
      "type": "shell",
      "command": "npx expo start --ios",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": [],
      "windows": {
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        },
        "command": "echo iOS Simulator requires macOS + Xcode. On Windows use task \"Expo: Web\" or \"Expo: Android\", or a physical iPhone with Expo Go. See DEVELOPMENT.md && exit /b 1"
      }
    },
    {
      "label": "Expo: Android emulator (native phone)",
      "type": "shell",
      "command": "npm run phone:android",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
