{
  "name": "lingua",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start",
    "dev:lan-flask": "python lan_dev_server.py",
    "dev:with-lan-flask": "concurrently -n expo,flask -c cyan,magenta \"expo start\" \"python lan_dev_server.py\"",
    "start": "expo start",
    "android": "expo start --android",
    "phone:android": "node scripts/launch-android-phone.mjs",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "dev:tunnel": "expo start --tunnel",
    "preview:iphone-web": "node scripts/open-iphone-frame.cjs",
    "ios:prebuild": "expo prebuild --platform ios",
    "ios:xcode": "expo prebuild --platform ios && expo run:ios",
    "prebuild": "expo prebuild",
    "native:ios": "expo run:ios",
    "native:android": "expo run:android",
    "build:android:apk": "eas build -p android --profile preview",
    "build:ios": "eas build -p ios --profile production",
    "build:web": "expo export --platform web",
    "test:servers": "node scripts/test-servers.mjs"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-mono": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.8",
    "date-fns": "2.30.0",
    "expo": "~54.0.33",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video": "~3.0.16",
    "expo-web-browser": "~15.0.10",
    "knotapi-js": "^1.1.1",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "tailwindcss": "^3.4.19",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "@types/react": "~19.1.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
